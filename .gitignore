# Virtual environment
venv/

# Hidden files and folders (dot-prefixed), but not .gitignore itself
.*
!.gitignore
!.env.example

# .env contains secrets — never commit it; use .env.example as the template
.env

# Python cache
__pycache__/
*.py[cod]
*.pyo

# ONNX model exports
#onnx_model/

# Downloaded model weights — large binary files, don't commit them
#model/
