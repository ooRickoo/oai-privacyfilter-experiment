# ──────────────────────────────────────────────────────────────────────────────
#  .env.example — OpenAI Privacy Filter
# ──────────────────────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values:
#      cp .env.example .env
#
#  .env is git-ignored.  Never commit real tokens to source control.
# ──────────────────────────────────────────────────────────────────────────────


# ── Hugging Face model identity ───────────────────────────────────────────────
# The Hugging Face repo ID for the privacy filter model.
HF_MODEL_ID=openai/privacy-filter

# ── Local model path ──────────────────────────────────────────────────────────
# Where download_model.py saves (and demo.py loads) the model weights.
# This path is relative to the project root.
LOCAL_MODEL_DIR=model/openai-privacy-filter

# ── Offline mode ──────────────────────────────────────────────────────────────
# Set to 1 after running download_model.py to prevent ANY outbound network
# calls to huggingface.co.  Required when running behind a proxy that blocks
# access to Hugging Face.
#
# Uncomment the line below once the model has been downloaded locally:
# TRANSFORMERS_OFFLINE=1

# ── Hugging Face authentication (optional) ────────────────────────────────────
# Required only if the model repo is private or gated.
# Create a token at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── HF cache override (optional) ─────────────────────────────────────────────
# By default Hugging Face caches models in ~/.cache/huggingface/hub/.
# Uncomment and set a custom path if you need a shared or non-default location.
# HF_HOME=/path/to/shared/huggingface/cache
